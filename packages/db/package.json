{
    "name":  "@phish-guard-app/db",
    "type":  "module",
    "exports":  {
                    ".":  {
                              "default":  "./src/index.ts"
                          },
                    "./*":  {
                                "default":  "./src/*.ts"
                            }
                },
    "scripts":  {
                    "db:push":  "prisma db push --schema=./prisma/schema",
                    "db:generate":  "prisma generate --schema=./prisma/schema",
                    "db:migrate":  "prisma migrate dev --schema=./prisma/schema",
                    "db:studio":  "prisma studio --schema=./prisma/schema",
                    "db:backfill:org-departments":  "prisma db execute --file=./prisma/scripts/backfill_org_departments.sql",
                    "db:seed":  "tsx seed.ts"
                },
    "dependencies":  {
                         "@phish-guard-app/auth":  "workspace:*",
                         "@phish-guard-app/env":  "workspace:*",
                         "@prisma/adapter-pg":  "7.8.0",
                         "@prisma/client":  "7.8.0",
                         "dotenv":  "catalog:"
                     },
    "devDependencies":  {
                            "@phish-guard-app/config":  "workspace:*",
                            "@node-rs/argon2":  "^1.8.3",
                            "prisma":  "7.8.0",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.0.0"
                        }
}
