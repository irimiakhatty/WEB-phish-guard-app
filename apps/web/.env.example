# Database — use the same Neon URL locally and on Vercel (see docs/DEV_DATABASE.md)
# Pull from Vercel: vercel env pull apps/web/.env.vercel --environment=development
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
# Local Docker fallback (optional, single machine):
# DATABASE_URL=postgresql://phishguard:phishguard_dev_password@localhost:5432/phishguard

# Seed — `bun run db:bootstrap` (empty DB) or `bun run db:seed` (refresh demo)
# SEED_DEMO=false          # skip demo org/users
# DEMO_RESET=true          # delete and recreate acme-romania demo data
# ADMIN_RESET=true         # reset super admin password (see seed/admin.ts)
# Demo password for all seeded users: Demo@123456

# Authentication
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long
BETTER_AUTH_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ML Service
ML_SERVICE_URL=http://localhost:5000

# Analyze Payload Encryption (optional, recommended for extension traffic)
# Public key is sent to extension; private key stays server-side.
# Generate escaped env values with:
# bun run --filter web keys:analyze -- --out apps/web/.env.analyze.keys
ANALYZE_PAYLOAD_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ANALYZE_PAYLOAD_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Deep Scan (extension button on medium/high emails)
# Generate keys: bun run --filter web keys:analyze
# Then copy apps/web/.env.analyze.keys into this file.
DEEP_SCAN_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
DEEP_SCAN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Optional. Leave unset on Vercel to run Deep Scan inline on the web app (no extra microservice).
# Local dev only:
# DEEP_SCAN_INFERENCE_URL=http://localhost:3001/api/internal/deep-scan-inference
# DEEP_SCAN_INFERENCE_TOKEN=optional-shared-secret

# Notion context sync (optional)
NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_SYNC_OUT_DIR=./notion-sync
NOTION_SYNC_PAGE_SIZE=50

# Google Safe Browsing
GOOGLE_SAFE_BROWSING_API_KEY=your-google-api-key

# Cloudmersive Phishing Detection (Deep Scan AI — text + embedded URLs)
# Get a free key: https://portal.cloudmersive.com/signup
CLOUDMERSIVE_API_KEY=your-cloudmersive-api-key

# Privacy / Retention Policy (recommended defaults)
# Keep safe-user content out of storage unless explicitly enabled.
STORE_SAFE_CONTENT=false
# Keep safe URLs out of storage by default (GDPR strict).
STORE_SAFE_URL=false
# If enabled, overrides retention and keeps text for investigations.
FORENSICS_MODE=false
# Optional advanced retention controls
STORE_PHISHING_CONTENT=false
STORE_PHISHING_URL=true
STORE_FULL_URL=false

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (Test Mode Keys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRICE_PERSONAL_PLUS_MONTHLY=price_...
STRIPE_PRICE_PERSONAL_PRO_MONTHLY=price_...
STRIPE_PRICE_TEAM_STARTUP_MONTHLY=price_...
STRIPE_PRICE_TEAM_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_TEAM_ENTERPRISE_MONTHLY=price_...

# Extension (Optional)
NEXT_PUBLIC_EXTENSION_ID=your-chrome-extension-id

# API Rate Limits (Optional)
API_RATE_LIMIT_HOURLY=100
API_RATE_LIMIT_ANONYMOUS=50

# SMTP for invites (Optional but required for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=abcdefghijklmnopqrstuvwxyz@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=abcdefghijklmnopqrstuvwxyz@gmail.com

# Cron jobs (required in production for scheduled jobs)
CRON_SECRET=replace-with-long-random-string

# Training reminders (days before due date to trigger reminder emails)
TRAINING_REMINDER_LOOKAHEAD_DAYS=2

# Environment
NODE_ENV=development
